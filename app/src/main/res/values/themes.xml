<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyTV" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- 平板端设置弹窗：居中显示，带圆角背景 -->
    <style name="Theme.MyTV.Dialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@drawable/rounded_dialog</item>
        <item name="android:windowElevation">8dp</item>
        <item name="android:windowMinWidthMajor">40%</item>
        <item name="android:windowMinWidthMinor">60%</item>
    </style>
</resources>
